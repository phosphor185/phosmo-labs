#include <stdio.h>

#define MAXN 100005

/* Переменные объявлены вне циклов, как требовалось */
int N, L;
int A[MAXN]; /* Структура дерева (считываем, но для ответа не нужна) */
int B[MAXN]; /* Длины ходов */
int i;
long long total_len = 0;

int main() {
    /* Оптимизация буферов для быстрого ввода-вывода */
    setvbuf(stdin, NULL, _IOFBF, 1 << 16);
    setvbuf(stdout, NULL, _IOFBF, 1 << 16);

    if (scanf("%d %d", &N, &L) != 2) return 0;

    /* Читаем связи (номера родительских вершин) */
    for (i = 0; i < N - 1; ++i) {
        scanf("%d", &A[i]);
    }

    /* Читаем длины ходов и сразу считаем общую длину норы */
    for (i = 0; i < N - 1; ++i) {
        scanf("%d", &B[i]);
        total_len += B[i];
    }

    /* Жадный ответ: сколько раз длина червяка помещается в общую длину */
    printf("%lld\n", total_len / L);
    
    return 0;
}

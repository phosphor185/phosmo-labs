#include <stdio.h>

int main() {
    int N, L;
    scanf("%d %d", &N, &L);

    int temp;
    for (int i = 0; i < N - 1; i++) 
        scanf("%d", &temp);

    int total = 0, len;
    for (int i = 0; i < N - 1; i++) {
        scanf("%d", &len);
        total += len / L;
    }

    printf("%d\n", total);
    return 0;
}

В третьей строке N − 1 целых чисел B[0] , ... , B[N −2] , (1 ⩽ B[i] ⩽ 100),
 где B[i] – длина ребра из вершины A[i] в вершину i + 1.

Формат выходных данных
В единственной строке выведите целое число – максимальное количество червяков, которое мо-
жет разместиться в норе.

Пример:
standard input           standard output 

3 2                      3
0 1 
3 4

#include <stdio.h>

#define MAXN 100005

/* Переменные объявлены вне циклов и функций, как требовалось */
int N, L;
int A[MAXN]; /* Массив родителей (считываем, но не используем для подсчёта) */
int B[MAXN]; /* Массив длин ходов */
int i;
long long ans = 0;

int main() {
    /* Ускоряем ввод-вывод на случай больших тестов */
    setvbuf(stdin, NULL, _IOFBF, 1 << 16);
    setvbuf(stdout, NULL, _IOFBF, 1 << 16);

    if (scanf("%d %d", &N, &L) != 2) {
        return 0;
    }

    /* Считываем структуру дерева (номера вершин-родителей) */
    for (i = 0; i < N - 1; ++i) {
        scanf("%d", &A[i]);
    }

    /* Считываем длины ходов и сразу применяем жадную стратегию */
    for (i = 0; i < N - 1; ++i) {
        scanf("%d", &B[i]);
        ans += B[i] / L;
    }

    printf("%lld\n", ans);
    return 0;
}

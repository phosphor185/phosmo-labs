#include <math.h>    // для sqrt

typedef struct {
    double x;
    double y;
} POINT;

typedef struct {
    int n;
    POINT *p;
} POLY;

// Расстояние между двумя точками
double dist(POINT p1, POINT p2) {
    double dx = p2.x - p1.x;
    double dy = p2.y - p1.y;
    return sqrt(dx * dx + dy * dy);
}

// Периметр многоугольника
double perimetr(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += dist(p->p[i], p->p[(i + 1) % p->n]);
    }
    return s;
}

// Площадь многоугольника (формула Гаусса)
double area(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        int j = (i + 1) % p->n;
        s += p->p[i].x * p->p[j].y - p->p[j].x * p->p[i].y;
    }
    return fabs(s) / 2.0;
}


#include <stdio.h>
#include <stdlib.h>
#include <math.h>

typedef struct {
    double x;
    double y;
} POINT;

typedef struct {
    int n;
    POINT *p;
} POLY;

// Расстояние между двумя точками
double dist(POINT p1, POINT p2) {
    double dx = p2.x - p1.x;
    double dy = p2.y - p1.y;
    return sqrt(dx * dx + dy * dy);
}

// Ориентация трех точек
// Возвращает: 0 - коллинеарны, 1 - по часовой, 2 - против часовой
int orientation(POINT p, POINT q, POINT r) {
    double val = (q.y - p.y) * (r.x - q.x) - (q.x - p.x) * (r.y - q.y);
    
    if (fabs(val) < 1e-10) return 0;  // Коллинеарны
    return (val > 0) ? 1 : 2;  // 1 - по часовой, 2 - против
}

// Проверка принадлежности точки q отрезку pr
int onSegment(POINT p, POINT q, POINT r) {
    return (q.x <= fmax(p.x, r.x) && q.x >= fmin(p.x, r.x) &&
            q.y <= fmax(p.y, r.y) && q.y >= fmin(p.y, r.y));
}

// Проверка пересечения двух отрезков
int doIntersect(POINT p1, POINT q1, POINT p2, POINT q2) {
    int o1 = orientation(p1, q1, p2);
    int o2 = orientation(p1, q1, q2);
    int o3 = orientation(p2, q2, p1);
    int o4 = orientation(p2, q2, q1);
    
    // Общий случай
    if (o1 != o2 && o3 != o4)
        return 1;
    
    // Специальные случаи (коллинеарность)
    if (o1 == 0 && onSegment(p1, p2, q1)) return 1;
    if (o2 == 0 && onSegment(p1, q2, q1)) return 1;    if (o3 == 0 && onSegment(p2, p1, q2)) return 1;
    if (o4 == 0 && onSegment(p2, q1, q2)) return 1;
    
    return 0;  // Не пересекаются
}

// Проверка самопересечения многоугольника
int isSelfIntersecting(POLY *p) {
    // Треугольник не может иметь самопересечений
    if (p->n < 4)
        return 0;
    
    for (int i = 0; i < p->n; i++) {
        POINT a1 = p->p[i];
        POINT a2 = p->p[(i + 1) % p->n];
        
        for (int j = i + 2; j < p->n; j++) {
            // Пропускаем смежные отрезки
            if (j == (i + 1) % p->n)
                continue;
            
            // Для последнего отрезка пропускаем первый (они смежные)
            if (i == 0 && j == p->n - 1)
                continue;
                
            POINT b1 = p->p[j];
            POINT b2 = p->p[(j + 1) % p->n];
            
            if (doIntersect(a1, a2, b1, b2)) {
                return 1;  // Есть пересечение
            }
        }
    }
    return 0;  // Нет пересечений
}

// Периметр многоугольника
double perimetr(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += dist(p->p[i], p->p[(i + 1) % p->n]);
    }
    return s;
}

// Площадь многоугольника (формула Гаусса)
double area(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        int j = (i + 1) % p->n;        s += p->p[i].x * p->p[j].y - p->p[j].x * p->p[i].y;
    }
    return fabs(s) / 2.0;
}

int main(int argc, char *argv[]) {
    if (argc < 2) {
        printf("Использование: %s <файл_с_координатами>\n", argv[0]);
        return 1;
    }
    
    FILE *f = fopen(argv[1], "r");
    if (!f) {
        printf("Ошибка: не удалось открыть файл %s\n", argv[1]);
        return 1;
    }
    
    POLY p;
    if (fscanf(f, "%d", &p.n) != 1) {
        printf("Ошибка чтения количества вершин\n");
        fclose(f);
        return 1;
    }
    
    p.p = malloc(p.n * sizeof(POINT));
    if (!p.p) {
        printf("Ошибка выделения памяти\n");
        fclose(f);
        return 1;
    }
    
    for (int i = 0; i < p.n; i++) {
        if (fscanf(f, "%lf %lf", &p.p[i].x, &p.p[i].y) != 2) {
            printf("Ошибка чтения координат точки %d\n", i);
            free(p.p);
            fclose(f);
            return 1;
        }
    }
    
    fclose(f);
    
    printf("Количество вершин: %d\n", p.n);
    
    // Проверка на самопересечение
    if (isSelfIntersecting(&p)) {
        printf("ВНИМАНИЕ: Многоугольник имеет самопересечения!\n");
    } else {
        printf("Многоугольник простой (нет самопересечений)\n");
        printf("Периметр: %.2f\n", perimetr(&p));        printf("Площадь: %.2f\n", area(&p));
    }
    
    free(p.p);
    return 0;
}
